{
  "manifest_version": 2,
  "version": "2.0.0",
  "name": "B站动态推送 (Bilibili Dynamic Push Plugin)",
  "description": "适用于MaiSaKa的B站动态订阅与直播状态自动推送插件",
  "author": {
    "name": "白狐",
    "url": "https://github.com/whitefox20011120"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com/whitefox20011120/bilibili_dynamic_push_plugin",
    "homepage": "https://github.com/whitefox20011120",
    "documentation": "https://github.com/whitefox20011120/bilibili_dynamic_push_plugin",
    "issues": "https://github.com/whitefox20011120/bilibili_dynamic_push_plugin"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [],
  "capabilities": [
    "send.text",
    "send.image",
    "config.get",
    "chat.get_group_streams",
    "chat.get_stream_by_group_id"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "locales_path": "_locales",
    "supported_locales": [
      "zh-CN"
    ]
  },
  "id": "whitefox.bilibili-dynamic-push"
}
