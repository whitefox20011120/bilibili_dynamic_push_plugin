{
  "manifest_version": 2,
  "version": "2.1.0",
  "name": "B站动态推送",
  "description": "适用于MaiBot的B站动态订阅与直播状态自动推送插件（旧版请去仓库分支）",
  "author": {
    "name": "白狐",
    "url": "https://github.com/whitefox20011120"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com/whitefox20011120/bilibili_dynamic_push_plugin"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [],
  "capabilities": [
    "config.get",
    "api.call"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "locales_path": "_locales",
    "supported_locales": [
      "zh-CN"
    ]
  },
  "id": "whitefox.bilibili-dynamic-push"
}
